{
  "name": "@device-knowledge/rdk-knowledge",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Data-first RDK device knowledge module for device-knowledge.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-md-assets.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/*.spec.mjs",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@device-knowledge/core": "0.1.0"
  },
  "devDependencies": {
    "@device-knowledge/dmoss-adapter": "0.1.0",
    "typescript": "^5.7.3"
  },
  "engines": { "node": ">=22.16.0" },
  "keywords": ["device-knowledge", "rdk", "robotics", "d-robotics"]
}
