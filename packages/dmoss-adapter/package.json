{
  "name": "@device-knowledge/dmoss-adapter",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Adapter that converts device-knowledge modules into the D-Moss KnowledgeModule contract.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/*.spec.mjs",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@device-knowledge/core": "0.1.0",
    "@dmoss/core": "file:../../../moss/packages/dmoss"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": { "node": ">=22.16.0" },
  "keywords": ["device-knowledge", "dmoss", "adapter", "knowledge-module", "robotics"]
}
